# Shared
SUPABASE_URL=https://bfjotlymigmxjnlwvmdi.supabase.co
SUPABASE_SERVICE_ROLE_KEY=__ROTATED_SERVICE_ROLE_KEY__

# Required for validating Supabase Auth JWTs in the API when AUTH_ENABLED=true
SUPABASE_ANON_KEY=__SUPABASE_ANON_KEY__

# Auth/tenancy enforcement (incremental rollout)
AUTH_ENABLED=false
AUTH_STRICT=false
TENANT_MEMBERS_TABLE=tenant_members

# Supabase Postgres connection string (for pg-boss). Use the *transaction pooler* or direct connection.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
PG_BOSS_SCHEMA=pgboss

# Evolution
EVOLUTION_API_URL=https://evolution.magicti.com
EVOLUTION_API_KEY=__EVOLUTION_API_KEY__

# Public base URL where Evolution can reach your API webhook
PUBLIC_API_BASE_URL=https://gestorapi.seudominio.com

# Temporary global secret for webhook validation (optional, prefer per-instance lookup)
EVOLUTION_WEBHOOK_SECRET=

# Ports
PORT=3011
